[core]
	editor = vim
	excludesfile = ~/.gitignore_global
[alias]
	st = status -sb
	lg = log --graph --pretty=format:'%Cred%h%Creset %s' --abbrev-commit
[color]
	ui = auto
[diff]
	colorMoved = default
