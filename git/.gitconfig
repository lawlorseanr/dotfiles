# Shared git defaults — personal name/email go in ~/.gitconfig.local

[include]
	path = ~/.gitconfig.local

[init]
	defaultBranch = main

[core]
	editor = vim
	excludesfile = ~/.gitignore_global
	pager = less -FRX

[pull]
	rebase = false

[push]
	default = simple
	autoSetupRemote = true

[color]
	ui = auto

[alias]
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	ca = commit --amend
	dc = diff --cached
	df = diff
	lg = log --graph --pretty=format:'%Cred%h%Creset %s %Cgreen(%cr)%Creset' --abbrev-commit
	last = log -1 HEAD --stat
	unstage = reset HEAD --
	aliases = config --get-regexp alias

[diff]
	colorMoved = default

[merge]
	conflictstyle = diff3

[help]
	autocorrect = 1
